# ============================================================
# Portfolio Analyzer Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Database
# SQLite path. For local single-user use the default is fine.
# -----------------------------------------------------------
DATABASE_URL=sqlite:///./portfolio.db

# -----------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# -----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------
# AI features
#
# There is NOTHING to configure here. The AI review/suggestions
# are PROMPT-ONLY: the app assembles a prompt that you run in
# your own Claude/ChatGPT (your subscription — no API key), and
# you paste the JSON it returns back into the app. Your chat
# model fetches Yahoo Finance data and researches the news
# itself, via its own subagents.
# -----------------------------------------------------------

# -----------------------------------------------------------
# Market Data Provider
# Provides live prices, stats, and history for the app's own
# dashboards (holdings + watchlist). Currently only "yfinance"
# is supported — an unofficial Yahoo Finance wrapper that needs
# no API key. It may break if Yahoo Finance changes its API.
# (The AI features do NOT use this; the chat model fetches its
# own market data.)
# -----------------------------------------------------------
MARKET_DATA_PROVIDER=yfinance
