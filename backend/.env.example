# ============================================================
# Portfolio Analyzer Backend – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Database
# SQLite path. For local single-user use the default is fine.
# -----------------------------------------------------------
DATABASE_URL=sqlite:///./portfolio.db

# -----------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# -----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------
# AI Provider
# Choose which AI backend to use: "openai" or "claude"
# -----------------------------------------------------------
AI_PROVIDER=openai

# AI web search — when true, the dashboard "AI Suggestions" agent uses the
# provider's native web search to factor in CURRENT sentiment and the forward
# outlook (recent news, results, analyst views), not just past performance.
# Adds latency/cost per review; set false to disable. Degrades gracefully.
AI_WEB_SEARCH=true
AI_WEB_SEARCH_MAX_USES=6

# -----------------------------------------------------------
# Market Data Provider
# Provides live prices, stats, and history for holdings and
# the watchlist.  Currently only "yfinance" is supported.
# yfinance is an unofficial Yahoo Finance wrapper and requires
# no API key.  It may break if Yahoo Finance changes its API.
# -----------------------------------------------------------
MARKET_DATA_PROVIDER=yfinance

# -----------------------------------------------------------
# OpenAI
#
# IMPORTANT: A ChatGPT subscription (chat.openai.com) is NOT
# the same as OpenAI API access. You need a separate API key
# from platform.openai.com → API keys. These are billed
# per-token independently of any ChatGPT plan.
# -----------------------------------------------------------
OPENAI_API_KEY=sk-...your-platform.openai.com-api-key-here...
OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------
# Anthropic / Claude
# API key from console.anthropic.com → API keys.
# -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-api-key-here...
ANTHROPIC_MODEL=claude-sonnet-4-6
